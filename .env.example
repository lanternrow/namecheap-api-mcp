# Namecheap MCP credentials — copy this file to ".env" and fill in real values.
# The ".env" file is gitignored and must NEVER be committed or shared.

# Your Namecheap account username (the API user).
NAMECHEAP_API_USER=

# The API key from Profile -> Tools -> Namecheap API Access.
NAMECHEAP_API_KEY=

# The public IPv4 of the machine running this server, whitelisted in your
# Namecheap account. For this machine it is 71.205.194.107.
NAMECHEAP_CLIENT_IP=71.205.194.107

# Optional. Defaults to NAMECHEAP_API_USER. Only differs for reseller sub-users.
NAMECHEAP_USERNAME=

# Optional. "production" (default) or "sandbox".
NAMECHEAP_ENVIRONMENT=production
